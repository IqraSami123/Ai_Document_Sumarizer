# Application
APP_NAME="AI Document Summarizer"
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
HOST_PORT=8001

# OpenAI
# Never commit a real key. Set this only in your local secret store or deployment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SUMMARY_WORD_TARGET=150
MAX_PDF_SIZE_BYTES=20971520
MAX_PDF_PAGES=200
MAX_SUMMARY_INPUT_CHARACTERS=100000
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2

# Optional: protects /api endpoints when set. Browser clients must send X-API-Key.
API_ACCESS_KEY=
CORS_ORIGINS=
LOG_LEVEL=INFO
